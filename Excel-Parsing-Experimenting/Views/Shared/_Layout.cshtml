<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Excel Parsing Experimenting</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Excel_Parsing_Experimenting.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="shell">
            <nav class="topbar__nav">
                <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">X</span>
                    <span>Excel Parsing Experimenting</span>
                </a>
                <div class="topbar__links">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Upload Lab</a>
                    <a href="@Url.Action("Index", "Home")#sample-files">Sample Files</a>
                </div>
            </nav>
        </div>
    </header>
    <div class="shell">
        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-shell">
        <div class="shell footer-shell__inner">
            <span>&copy; 2026 Excel Parsing Experimenting</span>
            <span>Rebuilt as ASP.NET Core MVC on .NET 10</span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
